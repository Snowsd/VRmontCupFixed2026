"3": {
&"character": "DETECTIVE POSEÍDO",
&"id": "3",
&"next_id": "4",
&"text": "¡Tu alma! Tan pura… tan luminosa… ¡Será mía!",
&"type": "dialogue"
},
"4": {
&"character": "DETECTIVE ESQUELETUM",
&"id": "4",
&"next_id": "5",
&"text": "¡No, niño! ¡No escuches su voz! Estoy atrapado… poseído… ¡Aléjate!",
&"type": "dialogue"
},
"5": {
&"character": "DETECTIVE POSEÍDO",
&"id": "5",
&"next_id": "6",
&"text": "Muajajajajaja… ¡No podrás escapar de mí!",
&"type": "dialogue"
},
"6": {
&"character": "DETECTIVE ESQUELETUM",
&"id": "6",
&"next_id": "7",
&"text": "¡Rápido! ¡El dragón custodia la melodía! Si la tocas, quizás suceda algo.",
&"type": "dialogue"
},
"7": {
&"character": "TIM",
&"id": "7",
&"next_id": "8",
&"text": "¿La melodía…? ¡Entonces es la clave para salir!",
&"type": "dialogue"
},
"8": {
&"character": "DETECTIVE POSEÍDO",
&"id": "8",
&"next_id": "9",
&"text": "¡Calla, despojo! ¡El niño es mío!",
&"type": "dialogue"
},
"9": {
&"character": "DETECTIVE ESQUELETUM",
&"id": "9",
&"next_id": "11",
&"text": "¡Toca la melodía, Tim! ¡Hazlo antes de que sea tarde!",
&"type": "dialogue"
}
}
raw_text = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
~ start
DETECTIVE POSEÍDO: ¡Tu alma! Tan pura… tan luminosa… ¡Será mía!  
DETECTIVE ESQUELETUM: ¡No, niño! ¡No escuches su voz! Estoy atrapado… poseído… ¡Aléjate!  
DETECTIVE POSEÍDO: Muajajajajaja… ¡No podrás escapar de mí!  
DETECTIVE ESQUELETUM: ¡Rápido! ¡El dragón custodia la melodía! Si la tocas, quizás suceda algo.  
TIM: ¿La melodía…? ¡Entonces es la clave para salir!  
DETECTIVE POSEÍDO: ¡Calla, despojo! ¡El niño es mío!  
DETECTIVE ESQUELETUM: ¡Toca la melodía, Tim! ¡Hazlo antes de que sea tarde!  

=> END
"
metadata/dialogue_manager_version = "3.7.1"
