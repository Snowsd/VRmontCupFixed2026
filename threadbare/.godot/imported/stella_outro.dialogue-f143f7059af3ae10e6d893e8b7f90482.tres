raw_text = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
~ start
That night, back in her own bed, Stella looks up at Orion’s Belt. But now, she sees more than a hunter.
She sees a hearth, a canoe, a tortoise’s path.
The sky hasn’t changed. But she has.
=> END
"
metadata/dialogue_manager_version = "3.7.1"
