raw_text = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
~ start
Angel: Bienvenido, Tim… Sabía que llegarías hasta aquí. 
Este lugar guarda las llaves que abrirán la salida del laberinto.
No tengas miedo. Yo estaré a tu lado para guiarte… pero recuerda 
cada rincón de este laberinto pondrá a prueba tu valor.
{{player_name}}: Gracias… No me rendiré. Haré todo lo posible para salvarla.
=> END

"
metadata/dialogue_manager_version = "3.7.1"
