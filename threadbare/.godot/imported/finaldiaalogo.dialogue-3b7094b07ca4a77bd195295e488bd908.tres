"20": {
&"character": "Tim",
&"id": "20",
&"next_id": "21",
&"text": "Te busqué en todas partes... creí que te había perdido para siempre.",
&"type": "dialogue"
},
"21": {
&"character": "Lily",
&"id": "21",
&"next_id": "22",
&"text": "Nunca estuve lejos. Siempre estuve contigo, en tus recuerdos y en tu valor.",
&"type": "dialogue"
},
"22": {
&"character": "Tim",
&"id": "22",
&"next_id": "23",
&"text": "Pero dudé tanto, Lily… tuve miedo de no ser lo suficientemente fuerte.",
&"type": "dialogue"
},
"23": {
&"character": "Lily",
&"id": "23",
&"next_id": "24",
&"text": "Fuiste valiente cuando importaba. El miedo no te hizo débil, te hizo humano. Y elegiste enfrentarlo.",
&"type": "dialogue"
},
"24": {
&"character": "TIM",
&"id": "24",
&"next_id": "25",
&"text": "Ahora lo entiendo. No vencí al bosque ni al demonio… vencí a mi propio miedo.",
&"type": "dialogue"
},
