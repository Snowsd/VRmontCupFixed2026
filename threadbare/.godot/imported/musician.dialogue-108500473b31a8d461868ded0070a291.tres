&"id": "11",
&"next_id": "12",
&"text": "Ah! Another wanderer. Welcome to the Song Sanctuary. Or what's left of it.",
&"type": "dialogue"
},
"12": {
&"character": "StoryWeaver",
&"id": "12",
&"next_id": "13",
&"text": "What happened here?",
&"type": "dialogue"
},
"13": {
&"character": "Musician",
&"id": "13",
&"next_id": "14",
&"text": "Songs stopped being sung. And when a song is forgotten... the world forgets itself.",
&"type": "dialogue"
},
