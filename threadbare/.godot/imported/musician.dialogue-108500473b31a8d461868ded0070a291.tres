"15": {
&"character": "Musician",
&"id": "15",
&"next_id": "16",
&"text": "Oh! Have you been playing with the stones over there?",
&"type": "dialogue"
},
"16": {
&"character": "StoryWeaver",
&"id": "16",
&"next_id": "17",
&"text": "I tapped them and something strange happened...",
&"type": "dialogue"
},
"17": {
&"character": "Musician",
&"id": "17",
&"next_id": "20",
&"text": "They can be used to create music...",
