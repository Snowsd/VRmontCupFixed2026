raw_text = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
~ start
{{player_name}}: Do you know why Orion is missing a star?
{{npc_name}}: Who is Orion? A hunter? No, child. Those three stars are the Hearthstones of Creation. The missing one? That was our fire.
{{npc_name}}: The Maize God once kindled the cosmic flame. Without it, the world is out of balance.
{{npc_name}}: But fire is never freely given. It must be taken back.
=> END
"
metadata/dialogue_manager_version = "3.7.1"
