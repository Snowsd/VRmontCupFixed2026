raw_text = "SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
~ start
Bryan: Charlie! Se abrio la entrada! Acompañame!
Charlie: ... casi acaban con nosotros.
Charlie: ...
Charlie: Desde cuando haces eso?
Gato: Miau! :3
=> END
"
