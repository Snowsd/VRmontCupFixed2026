raw_text = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
~ start
do animation_player.play(\"walk_into_scene\")
do animation_player.animation_finished
StoryWeaver: I've done it! I've recovered the elements of the story.
StoryWeaver: Now it's time to head back to Fray's End with the Memory, Imagination, and Spirit.
StoryWeaver: Reweaving this story back into the Loom will help mend the holes in this world.
do animation_player.play(\"walk_off_scene\")
do wait(1.0)
=> END
"
metadata/dialogue_manager_version = "3.7.1"
