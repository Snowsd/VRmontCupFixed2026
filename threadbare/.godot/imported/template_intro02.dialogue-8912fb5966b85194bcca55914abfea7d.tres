},
"15": {
&"character": "TIM",
&"id": "15",
&"next_id": "16",
&"text": "¡Dime cómo encontrarla! ¡Dime dónde buscar!",
&"type": "dialogue"
},
"16": {
&"character": "ELFO",
&"id": "16",
&"next_id": "17",
&"text": "Sus huellas aún existen… pero solo quien recuerde podrá verlas.",
&"type": "dialogue"
},
"17": {
&"character": "TIM",
&"id": "17",
&"next_id": "18",
&"text": "¿Qué camino? No veo nada...",
&"type": "dialogue"
},
