raw_text = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
~ start
Stella finds herself in the Kalahari Desert in Southern Africa, where she meets a Khoisan guardian of nature resting beneath the endless sky.
She approaches the Guardian and asks about the missing star.
=> END
~ well_done
Stella looks up at the night sky, and finally, she sees the missing star! Tired from her travels, she returns home.
=> END
"
metadata/dialogue_manager_version = "3.7.1"
