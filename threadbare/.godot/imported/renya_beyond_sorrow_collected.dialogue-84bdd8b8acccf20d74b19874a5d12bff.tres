raw_text = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
~ start
Renya: No puedo creerlo, todo este tiempo no fue necesario defensa…
Renya: Solo caminar y dejar que su luz me guiara.
Naiya: En Solara, Renya entendió que aceptar no es rendirse…
Es permitir que la luz encuentre espacio en la oscuridad.
Naiya: Y así, Renya sin conflictos logró conseguir el último hilo para que este vuelva a brillar.
=> END
"
metadata/dialogue_manager_version = "3.7.1"
