raw_text = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
~ start
do animation_player.play(&\"walk_on\")
do animation_player.animation_finished
Charlie: Oye, no me dejes solo.
Charlie: Si aparece otro fantasma gigante como ese, no creo que vuelva a salir tan bien...
Bryan: Mi mama debe estar por aqui.
Bryan: DEBE ESTAR CERCA!
do animation_player.play(&\"walk_closer\")
do animation_player.animation_finished
=> END
"
metadata/dialogue_manager_version = "3.7.1"
